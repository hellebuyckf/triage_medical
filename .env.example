# Copy this file to .env and fill in your values.
# Never commit .env — it contains secrets.

# ── HuggingFace ───────────────────────────────────────────────────────────────

# HuggingFace API token (read/write) — required for push_to_hub and gated models.
# Generate at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# HuggingFace username — used by 06_push_to_hub.py to construct repo IDs.
HF_USERNAME=your_hf_username

# ── Model ─────────────────────────────────────────────────────────────────────

# Base model used across all training scripts (10, 11, 12, 20, 21, 22).
# Use the instruct variant for better SFT convergence on small datasets (<10k examples).
# Switch to the base variant to train the chat format from scratch.
#
# Instruct (recommended): unsloth/Qwen3-1.7B        (no suffix = instruct, Unsloth convention)
# Base:                   unsloth/Qwen3-1.7B-Base
MODEL_NAME=unsloth/Qwen3-1.7B

# ── MLflow ────────────────────────────────────────────────────────────────────
# Tracking URI used by all training scripts (11, 12, 20, 21).
#
# dev  (default): leave unset — scripts fall back to sqlite:///mlflow.db
# demo          : set to the Cloud Run URL, or put in .env.demo
# MLFLOW_TRACKING_URI=https://mlflow-w7nnrc23ka-ew.a.run.app
