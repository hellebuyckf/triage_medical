# Copier en .env.demo et remplir les valeurs
# NE PAS commiter .env.demo

# ── MLflow server (Docker demo) ───────────────────────────────────────────────
# PostgreSQL (Cloud SQL)
DB_USER=mlflow
DB_PASSWORD=changeme
DB_HOST=10.42.32.3
DB_NAME=mlflow

# GCS (récupérer via : cd infra && terraform output mlflow_artifact_root)
ARTIFACT_ROOT=gs://oc-p14-mlflow-artifacts/artifacts

# ── MLflow client (scripts Python) ───────────────────────────────────────────
# URL du serveur MLflow sur Cloud Run — utilisée par les scripts d'entraînement.
# Usage : make train-sft ENV=demo
MLFLOW_TRACKING_URI=https://mlflow-w7nnrc23ka-ew.a.run.app
MLFLOW_TRACKING_USERNAME=admin
MLFLOW_TRACKING_PASSWORD=changeme
